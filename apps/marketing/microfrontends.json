{
  "$schema": "https://openapi.vercel.sh/microfrontends.json",
  "applications": {
    
    "acme-platform-marketing": {
       "routing": [
        {
          "paths": ["/marketing", "/marketing/:path*"]
        }
      ],
      "development": {
        "fallback": "acme-platform-marketing.vercel.app"
      }
    },
   
    "@acme/docs": {
      "routing": [
        {
          "paths": ["/docs", "/docs/:path*"]
        }
      ],
      "development": {
        "local": 3001
      }
    },
    "@acme/dashboard": {
      "routing": [
        {
          "paths": ["/app", "/app/:path*", "/settings", "/settings/:path*"]
        }
      ],
      "development": {
        "local": 3002
      }
    }
},
    "options":{
        "localProxyPort": 3042
    }
}